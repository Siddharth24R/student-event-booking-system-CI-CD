# JMeter generated reports and logs — do not commit
jmeter/report/
jmeter/results.jtl
jmeter.log

# Firebase service account key — NEVER commit this to git
*.json
!firebase.json
!firestore.indexes.json
!events.json

# Environment file containing API keys — NEVER commit this to git
.env

# Maven build output
target/

# IDE and editor files
.idea/
*.iml
.vscode/
*.class
.claude/

# PDF reference papers — do not redistribute
pdf/

# Report generator output (keep scripts, not generated docs)
report_generator/*.docx

# OS files
.DS_Store
Thumbs.db
