<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Student Event Booking API</display-name>

    <!-- Starts EventSyncScheduler on deploy; shuts it down on undeploy -->
    <listener>
        <listener-class>com.ntu.eventbooking.startup.AppStartupListener</listener-class>
    </listener>

    <!--
        Jersey 2.x servlet (org.glassfish.jersey) — NOT the Jersey 1.x class
        (com.sun.jersey). Using the wrong class causes ClassNotFoundException on startup.
        The init-param tells Jersey which package to scan for @Path resources and @Provider filters.
    -->
    <servlet>
        <servlet-name>jersey-servlet</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>jersey.config.server.provider.packages</param-name>
            <!-- Jersey scans these packages for @Path, @Provider, ContainerResponseFilter, etc. -->
            <param-value>com.ntu.eventbooking.resources,com.ntu.eventbooking.auth</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>jersey-servlet</servlet-name>
        <!-- All REST calls go through /api/* — e.g. /api/events, /api/students/subscribe -->
        <url-pattern>/api/*</url-pattern>
    </servlet-mapping>

    <!-- Serve index.html as the default welcome page -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
